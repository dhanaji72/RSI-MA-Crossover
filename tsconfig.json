{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./build",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "incremental": false,
    "removeComments": true,
    "sourceMap": false,
    "noEmitOnError": true
  },

  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs"
    }
  },

  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "coverage",
    ".next",
    "**/*.spec.ts",
    "**/*.test.ts",
    "src/oc_coi_calc.ts",
    "src/tools/nifty_rsi_smma.ts"
  ]
}